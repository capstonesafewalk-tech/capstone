rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Allow anyone to read and write incident photos (uploaded by mobile app users)
    match /incidents/{allPaths=**} {
      allow read: if true;
      allow write: if true;
    }
    // All other paths require authentication
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
